{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Three cycles demo",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/three_cycles_demo.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Score random rounds demo",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/score_random_rounds_demo.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Run tournament demo",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/run_tournament_demo.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        }
    ]
}
